{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Backtester (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "backend/cpp",
        "-B",
        "build",
        "-DCMAKE_BUILD_TYPE=Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Compile Backtester",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Build Backtester (Debug)",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
