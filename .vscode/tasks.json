{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure Backtester (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "backend/cpp",
        "-B",
        "build-debug",
        "-DCMAKE_BUILD_TYPE=Debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Prepare Build Directory",
      "type": "shell",
      "command": "mkdir",
      "args": [
        "-p",
        "build"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Build Backtester (CMake)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build-debug",
        "--target",
        "metis_backtester"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Configure Backtester (Debug)",
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Build Backtester (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "build-debug",
        "--target",
        "metis_backtester"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Configure Backtester (Debug)",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
