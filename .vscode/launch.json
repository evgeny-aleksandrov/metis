{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C++ Backtester: Drop",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build-debug/metis_backtester",
      "args": [
        "--symbol",
        "QQQ",
        "--strategy",
        "drop",
        "--csv",
        "data/processed/QQQ/1d.csv",
        "--output",
        "ui/public/latest.json",
        "--initial",
        "10000",
        "--x-min",
        "0.01",
        "--x-max",
        "0.05",
        "--x-step",
        "0.0025",
        "--y-min",
        "1",
        "--y-max",
        "15",
        "--y-step",
        "1",
        "--hold-min",
        "2",
        "--hold-max",
        "30",
        "--hold-step",
        "2",
        "--mode",
        "walk-forward",
        "--walk-train-months",
        "24",
        "--walk-test-months",
        "2"
      ],
      "cwd": "${workspaceFolder}",
      "terminal": "integrated",
      "preLaunchTask": "Build Backtester (Debug)"
    },
    {
      "name": "C++ Backtester: Gain",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build-debug/metis_backtester",
      "args": [
        "--symbol",
        "QQQ",
        "--strategy",
        "gain",
        "--csv",
        "data/processed/QQQ/1d.csv",
        "--output",
        "ui/public/latest.json",
        "--initial",
        "10000",
        "--x-min",
        "0.01",
        "--x-max",
        "0.05",
        "--x-step",
        "0.0025",
        "--y-min",
        "1",
        "--y-max",
        "15",
        "--y-step",
        "1",
        "--hold-min",
        "2",
        "--hold-max",
        "30",
        "--hold-step",
        "2"
      ],
      "cwd": "${workspaceFolder}",
      "terminal": "integrated",
      "preLaunchTask": "Build Backtester (Debug)"
    },
    {
      "name": "C++ Backtester: Regime Full Feature Debug",
      "type": "lldb",
      "request": "launch",
      "program": "${workspaceFolder}/build-debug/metis_backtester",
      "args": [
        "--symbol",
        "QQQ",
        "--strategy",
        "regime",
        "--mode",
        "walk-forward",
        "--csv",
        "data/processed/QQQ/1h.csv",
        "--output",
        "ui/public/latest.json",
        "--initial",
        "20000",
        "--bars-per-year",
        "1764",
        "--fixed-cost",
        "0",
        "--variable-cost-rate",
        "0.0002",
        "--x-min",
        "0.005",
        "--x-max",
        "0.15",
        "--x-step",
        "0.005",
        "--y-min",
        "60",
        "--y-max",
        "400",
        "--y-step",
        "10",
        "--fast-lookback-min",
        "10",
        "--fast-lookback-max",
        "100",
        "--fast-lookback-step",
        "10",
        "--short-y-min",
        "30",
        "--short-y-max",
        "400",
        "--short-y-step",
        "20",
        "--short-fast-lookback-min",
        "10",
        "--short-fast-lookback-max",
        "100",
        "--short-fast-lookback-step",
        "10",
        "--take-profit-min",
        "0.01",
        "--take-profit-max",
        "0.15",
        "--take-profit-step",
        "0.01",
        "--stop-loss-min",
        "0.005",
        "--stop-loss-max",
        "0.08",
        "--stop-loss-step",
        "0.005",
        "--trailing-stop-min",
        "0.005",
        "--trailing-stop-max",
        "0.08",
        "--trailing-stop-step",
        "0.005",
        "--regime-weak-exit-mode",
        "both",
        "--short-mode",
        "both",
        "--vol-lookback-min",
        "30",
        "--vol-lookback-max",
        "400",
        "--vol-lookback-step",
        "20",
        "--target-vol-min",
        "0.10",
        "--target-vol-max",
        "0.40",
        "--target-vol-step",
        "0.02",
        "--max-position-pct-min",
        "0.25",
        "--max-position-pct-max",
        "1.0",
        "--max-position-pct-step",
        "0.2",
        "--grid-random-samples",
        "8000",
        "--grid-sample-seed",
        "42",
        "--walk-train-months",
        "48",
        "--walk-test-months",
        "3"
      ],
      "cwd": "${workspaceFolder}",
      "terminal": "integrated",
      "preLaunchTask": "Build Backtester (Debug)"
    },
    {
      "name": "Python Orchestrator: Drop",
      "type": "debugpy",
      "request": "launch",
      "module": "metis.backtest.runner",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "--symbol",
        "QQQ",
        "--strategy",
        "drop",
        "--output",
        "outputs/backtests/latest/report.json",
        "--x-min",
        "0.01",
        "--x-max",
        "0.05",
        "--x-step",
        "0.02",
        "--y-min",
        "2",
        "--y-max",
        "8",
        "--hold-min",
        "5",
        "--hold-max",
        "15",
        "--hold-step",
        "5"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Python Orchestrator: Gain",
      "type": "debugpy",
      "request": "launch",
      "module": "metis.backtest.runner",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "--symbol",
        "SPY",
        "--strategy",
        "gain",
        "--csv",
        "data/SPY.csv",
        "--output",
        "outputs/backtests/latest/report.json",
        "--x-min",
        "0.01",
        "--x-max",
        "0.05",
        "--x-step",
        "0.02",
        "--y-min",
        "2",
        "--y-max",
        "8",
        "--hold-min",
        "5",
        "--hold-max",
        "15",
        "--hold-step",
        "5"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "IBKR Fetch",
      "type": "debugpy",
      "request": "launch",
      "module": "metis.data.ibkr",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "IBKR_WEB_API_INSECURE": "true"
      },
      "args": [
        "--symbol",
        "QQQ",
        "--period",
        "6y",
        "--bar",
        "1d"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "IBKR Fetch: Hourly",
      "type": "debugpy",
      "request": "launch",
      "module": "metis.data.ibkr",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "IBKR_WEB_API_INSECURE": "true"
      },
      "args": [
        "--symbol",
        "QQQ",
        "--start-date",
        "2014-01-01",
        "--bar",
        "1h"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Live Scaffold: IBKR Session Only",
      "type": "debugpy",
      "request": "launch",
      "module": "metis.live.runner",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "IBKR_WEB_API_INSECURE": "true"
      },
      "args": [
        "--symbol",
        "SPY",
        "--paper"
      ],
      "console": "integratedTerminal"
    }
  ]
}
