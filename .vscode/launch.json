{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C++ Backtester: Drop",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/metis_backtester.exe",
      "args": [
        "--symbol",
        "QQQ",
        "--strategy",
        "drop",
        "--csv",
        "data/processed/QQQ/1d.csv",
        "--output",
        "ui/public/latest.json",
        "--initial",
        "10000",
        "--x-min",
        "0.01",
        "--x-max",
        "0.05",
        "--x-step",
        "0.0025",
        "--y-min",
        "1",
        "--y-max",
        "15",
        "--y-step",
        "1",
        "--hold-min",
        "2",
        "--hold-max",
        "30",
        "--hold-step",
        "2",
        "--mode",
        "walk-forward",
        "--walk-train-months",
        "24",
        "--walk-test-months",
        "2"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "preLaunchTask": "Compile Backtester (Direct Debug)",
      "MIMode": "gdb",
      "miDebuggerPath": "C:/Strawberry/c/bin/gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "C++ Backtester: Gain",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/metis_backtester.exe",
      "args": [
        "--symbol",
        "QQQ",
        "--strategy",
        "gain",
        "--csv",
        "data/processed/QQQ/1d.csv",
        "--output",
        "ui/public/latest.json",
        "--initial",
        "10000",
        "--x-min",
        "0.01",
        "--x-max",
        "0.05",
        "--x-step",
        "0.0025",
        "--y-min",
        "1",
        "--y-max",
        "15",
        "--y-step",
        "1",
        "--hold-min",
        "2",
        "--hold-max",
        "30",
        "--hold-step",
        "2"
      ],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "stopAtEntry": false,
      "preLaunchTask": "Compile Backtester (Direct Debug)",
      "MIMode": "gdb",
      "miDebuggerPath": "C:/Strawberry/c/bin/gdb.exe",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Python Orchestrator: Drop",
      "type": "debugpy",
      "request": "launch",
      "module": "metis.backtest.runner",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "--symbol",
        "QQQ",
        "--strategy",
        "drop",
        "--output",
        "outputs/backtests/latest/report.json",
        "--x-min",
        "0.01",
        "--x-max",
        "0.05",
        "--x-step",
        "0.02",
        "--y-min",
        "2",
        "--y-max",
        "8",
        "--hold-min",
        "5",
        "--hold-max",
        "15",
        "--hold-step",
        "5"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Python Orchestrator: Gain",
      "type": "debugpy",
      "request": "launch",
      "module": "metis.backtest.runner",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "--symbol",
        "SPY",
        "--strategy",
        "gain",
        "--csv",
        "data/SPY.csv",
        "--output",
        "outputs/backtests/latest/report.json",
        "--x-min",
        "0.01",
        "--x-max",
        "0.05",
        "--x-step",
        "0.02",
        "--y-min",
        "2",
        "--y-max",
        "8",
        "--hold-min",
        "5",
        "--hold-max",
        "15",
        "--hold-step",
        "5"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "IBKR Fetch",
      "type": "debugpy",
      "request": "launch",
      "module": "metis.data.ibkr",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "IBKR_WEB_API_INSECURE": "true"
      },
      "args": [
        "--symbol",
        "QQQ",
        "--period",
        "6y",
        "--bar",
        "1d"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Live Scaffold: IBKR Session Only",
      "type": "debugpy",
      "request": "launch",
      "module": "metis.live.runner",
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "IBKR_WEB_API_INSECURE": "true"
      },
      "args": [
        "--symbol",
        "SPY",
        "--paper"
      ],
      "console": "integratedTerminal"
    }
  ]
}
